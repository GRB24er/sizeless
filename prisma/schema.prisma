generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id @default(cuid())
  name      String
  phone     String
  email     String      @unique
  password  String
  status    USER_STATUS @default(OFFLINE)
  role      ROLE        @default(USER)
  shipments Shipment[]

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  profile       Profile?
  Notification  Notification[]
  ChatSession   ChatSession[]
  Message       Message[]
  adminPairings AdminUserPairing[] @relation("AdminPairings")
  vaultDeposits VaultDeposit[]
  vaultInvoices VaultInvoice[] @relation("VaultInvoices")
  vaultKYC      VaultKYC[]
}

model Address {
  id         String  @id @default(cuid())
  street     String?
  city       String?
  state      String?
  postalCode String?
  country    String?
  profileId  String  @unique
  Profile    Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Profile {
  id      String  @id @default(cuid())
  userId  String  @unique
  company String?
  bio     String?
  User    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Address   Address?
}

model Shipment {
  id                String    @id @default(cuid())
  trackingNumber    String    @unique
  estimatedDelivery DateTime
  deliveredAt       DateTime?
  isPaid            Boolean   @default(false)

  originAddress    String
  originCity       String
  originState      String
  originPostalCode String
  originCountry    String

  destinationAddress    String
  destinationCity       String
  destinationState      String
  destinationPostalCode String
  destinationCountry    String

  serviceType         String
  specialInstructions String?

  packages        Package[]
  TrackingUpdates TrackingUpdate[]
  fees            ShipmentFee[]
  recipient       Recipient        @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  recipientId     String
  Sender          User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  Notification Notification[]
}

model Package {
  id            String    @id @default(cuid())
  packageType   String
  weight        Int
  length        Int
  width         Int
  height        Int
  declaredValue Int?
  description   String
  pieces        Int
  dangerous     Boolean
  insurance     Boolean
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  Shipment      Shipment? @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  shipmentId    String
}

model Recipient {
  id        String     @id @default(cuid())
  name      String
  company   String?
  email     String?
  phone     String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  shipments Shipment[]
}

model TrackingUpdate {
  id         String   @id @default(cuid())
  shipmentId String
  timestamp  DateTime @default(now())
  location   String?
  message    String
  status     String?
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model ShipmentFee {
  id         String     @id @default(cuid())
  shipmentId String
  type       FEE_TYPE
  customType String?
  amount     Float
  currency   String     @default("USD")
  reason     String
  status     FEE_STATUS @default(UNPAID)

  invoiceNumber String  @unique @default(cuid())
  invoiceSentAt DateTime?
  paidAt        DateTime?
  receiptSentAt DateTime?

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id         String            @id @default(cuid())
  message    String
  type       NOTIFICATION_TYPE
  read       Boolean           @default(false)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  shipment   Shipment          @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  shipmentId String
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String?
  name      String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]
  pairing  AdminUserPairing?

  user User? @relation(fields: [userId], references: [id])
}

model Message {
  id            String   @id @default(cuid())
  chatSessionId String
  senderId      String?
  senderName    String?
  content       String
  role          ChatRole @default(USER)
  createdAt     DateTime @default(now())
  read          Boolean  @default(false)
  readBy        String?

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id])
  sender      User?       @relation(fields: [senderId], references: [id])
}

model AdminUserPairing {
  id            String   @id @default(cuid())
  chatSessionId String   @unique
  adminId       String
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updateAt      DateTime @updatedAt

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id])
  admin       User        @relation("AdminPairings", fields: [adminId], references: [id])

  @@unique([chatSessionId, adminId, active])
}

// ═══════════════════════════════════════════════════════════════
// VAULT SERVICE MODELS (ENHANCED)
// ═══════════════════════════════════════════════════════════════

model VaultKYC {
  id        String     @id @default(cuid())
  clientId  String
  status    KYC_STATUS @default(PENDING)

  idType          String?
  idNumber        String?
  idExpiryDate    DateTime?
  idDocumentUrl   String?

  addressDocType  String?
  addressDocUrl   String?

  sourceOfGold    String?
  sourceDocUrl    String?
  sourceNotes     String?

  corporateName   String?
  corporateRegNo  String?
  corporateDocUrl String?

  sanctionsCheck    AML_RESULT @default(PENDING)
  pepCheck          AML_RESULT @default(PENDING)
  adverseMediaCheck AML_RESULT @default(PENDING)
  amlNotes          String?

  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?

  client   User @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VaultDeposit {
  id            String       @id @default(cuid())
  depositNumber String       @unique
  status        VAULT_STATUS @default(KYC_REVIEW)

  intakeMethod      INTAKE_METHOD @default(CLIENT_DELIVERY)
  appointmentDate   DateTime?
  appointmentNotes  String?
  securityEscortRef String?

  assetType       ASSET_TYPE @default(GOLD_BAR)
  description     String
  weightGrams     Float
  purity          String?
  fineness        Float?
  quantity        Int        @default(1)
  serialNumbers   String?
  refinerName     String?
  refinerStamp    String?
  isLBMACertified Boolean    @default(false)

  declaredValue      Float
  verifiedValue      Float?
  spotPriceAtDeposit Float?

  assayStatus      ASSAY_STATUS @default(PENDING)
  assayMethod      String?
  assayResult      String?
  assayPerformedBy String?
  assayDate        DateTime?
  assayReportUrl   String?
  weightVerified   Float?
  weightDiscrepancy Float?

  storageType      STORAGE_TYPE @default(ALLOCATED)
  vaultLocation    String       @default("London Main Vault")
  storageUnit      String?
  shelfPosition    String?
  storageStartDate DateTime?
  storageEndDate   DateTime?

  insuredValue        Float?
  insuranceProvider   String?
  insurancePolicyNo   String?
  insuranceCoverage   String?
  insuranceExpiryDate DateTime?
  insuranceCertUrl    String?

  currency          String     @default("USD")
  monthlyStorageFee Float?
  insuranceFeeRate  Float?
  assayFee          Float?
  handlingFee       Float?
  totalFeesCharged  Float      @default(0)

  // Demurrage
  demurrageStartDate  DateTime?
  demurrageRate       Float?
  totalDemurrage      Float      @default(0)

  depositReceiptUrl   String?
  storageAgreementUrl String?
  custodyReferenceId  String?   @unique

  depositDate        DateTime  @default(now())
  kycApprovedAt      DateTime?
  intakeCompletedAt  DateTime?
  assayCompletedAt   DateTime?
  verifiedAt         DateTime?
  storedAt           DateTime?
  releaseRequestedAt DateTime?
  releaseApprovedAt  DateTime?
  releasedAt         DateTime?
  releaseReason      String?

  client      User              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String
  activities  VaultActivity[]
  withdrawals VaultWithdrawal[]
  invoices      VaultInvoice[]
  transfers     VaultTransfer[]
  beneficiaries VaultBeneficiary[]

  // Source of Funds / AML
  sourceOfFunds       String?
  sourceOfFundsDetail String?
  sourceOfFundsDocUrl String?
  sourceOfWealth      String?

  // Cash-specific
  cashCurrency        String?
  cashAmount          Float?
  cashSerialTracking  String?
  cashPackaging       String?

  // Jewelry-specific
  jewelryValuation    Float?
  jewelryValuationCertUrl String?
  jewelryPhotosUrl    String?

  // Document-specific
  documentTitle       String?
  documentIssuingAuth String?
  documentSerial      String?
  documentEnvelopeSeal String?

  // Chain of Custody
  receivedByName      String?
  receivedByTitle     String?
  entryTimestamp      DateTime?
  compartmentNumber   String?
  securityOfficerName String?
  cctvReferenceId     String?

  // Access Authorization
  authorizedPersons   String?
  withdrawalAuthMethod String?
  securityPin         String?

  // Compliance Screening
  sanctionsChecked    Boolean  @default(false)
  pepScreened         Boolean  @default(false)
  watchlistChecked    Boolean  @default(false)
  complianceStatus    String?
  complianceNotes     String?
  complianceOfficer   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model VaultActivity {
  id          String       @id @default(cuid())
  depositId   String
  action      VAULT_ACTION
  description String
  performedBy String?
  ipAddress   String?
  metadata    String?

  deposit   VaultDeposit @relation(fields: [depositId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
}

model VaultWithdrawal {
  id          String            @id @default(cuid())
  depositId   String
  type        WITHDRAWAL_TYPE   @default(PHYSICAL)
  status      WITHDRAWAL_STATUS @default(REQUESTED)

  requestedBy     String
  requestDate     DateTime       @default(now())
  requestNotes    String?

  authorizationDocUrl String?
  identityVerified    Boolean    @default(false)
  complianceCleared   Boolean    @default(false)
  complianceNotes     String?

  collectionMethod  INTAKE_METHOD?
  collectionDate    DateTime?
  securityEscortRef String?

  bullionDealerName  String?
  bullionDealerRef   String?
  spotPriceAtSale    Float?
  saleSpread         Float?
  saleAmount         Float?
  saleCurrency       String?    @default("USD")
  bankAccountRef     String?
  wireTransferRef    String?
  fundsTransferredAt DateTime?

  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  completedAt     DateTime?

  deposit VaultDeposit @relation(fields: [depositId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════

enum VAULT_STATUS {
  KYC_REVIEW
  KYC_APPROVED
  KYC_REJECTED
  INTAKE_SCHEDULED
  INTAKE_IN_PROGRESS
  PENDING_VERIFICATION
  ASSAY_IN_PROGRESS
  VERIFICATION_COMPLETE
  DOCUMENTED
  IN_STORAGE
  RELEASE_REQUESTED
  RELEASE_APPROVED
  RELEASED
  LIQUIDATION_IN_PROGRESS
  LIQUIDATED
  SUSPENDED
}

enum KYC_STATUS {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum AML_RESULT {
  PENDING
  CLEAR
  FLAGGED
  FAILED
}

enum ASSAY_STATUS {
  PENDING
  IN_PROGRESS
  PASSED
  FAILED
  WAIVED
}

enum STORAGE_TYPE {
  ALLOCATED
  SEGREGATED
  UNALLOCATED
}

enum ASSET_TYPE {
  GOLD_BAR
  GOLD_KILOBAR
  GOLD_COINS
  GOLD_DUST
  GOLD_DORE
  SILVER_BAR
  PLATINUM
  PALLADIUM
  JEWELRY
  PRECIOUS_STONES
  MIXED
}

enum INTAKE_METHOD {
  CLIENT_DELIVERY
  ARMORED_TRANSPORT
  VAULT_TRANSFER
}

enum VAULT_ACTION {
  KYC_SUBMITTED
  KYC_UNDER_REVIEW
  KYC_APPROVED
  KYC_REJECTED
  INTAKE_SCHEDULED
  INTAKE_STARTED
  INTAKE_COMPLETED
  PHYSICAL_INSPECTION
  ASSAY_STARTED
  ASSAY_COMPLETED
  ASSAY_FAILED
  WEIGHT_VERIFIED
  SERIAL_VERIFIED
  DEPOSIT_RECEIPT_ISSUED
  STORAGE_AGREEMENT_SIGNED
  INSURANCE_CERTIFICATE_ISSUED
  CUSTODY_REF_ASSIGNED
  PLACED_IN_STORAGE
  STORAGE_TYPE_CHANGED
  STORAGE_LOCATION_CHANGED
  INSURANCE_ACTIVATED
  INSURANCE_RENEWED
  INSURANCE_EXPIRED
  FEE_CHARGED
  FEE_PAID
  DEMURRAGE_CHARGED
  WITHDRAWAL_REQUESTED
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  WITHDRAWAL_COMPLETED
  LIQUIDATION_STARTED
  LIQUIDATION_COMPLETED
  FUNDS_TRANSFERRED
  STATUS_CHANGED
  NOTE_ADDED
  DEPOSIT_SUSPENDED
  DEPOSIT_REACTIVATED
  AUDIT_REQUESTED
  AUDIT_COMPLETED
}

enum WITHDRAWAL_TYPE {
  PHYSICAL
  LIQUIDATION
  VAULT_TRANSFER
}

enum WITHDRAWAL_STATUS {
  REQUESTED
  IDENTITY_VERIFIED
  COMPLIANCE_REVIEW
  APPROVED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum ChatRole {
  USER
  ADMIN
  BOT
}

enum NOTIFICATION_TYPE {
  DELIVERY_UPDATE
  PAYMENT_REMINDER
  SHIPMENT_CREATED
  STATUS_CHANGE
}

enum ROLE {
  USER
  ADMIN
  MANAGER
}

enum USER_STATUS {
  ONLINE
  AWAY
  OFFLINE
  ENDED
}

enum FEE_TYPE {
  AIRWAY_BILL
  SHIPPING_FREIGHT
  HOLD_RELEASE
  CUSTOMS_DUTY
  CUSTOM
}

enum FEE_STATUS {
  UNPAID
  PAID
  WAIVED
}

enum INVOICE_STATUS {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum INVOICE_ITEM_TYPE {
  STORAGE_FEE
  INTAKE_FEE
  ASSAY_FEE
  INSURANCE_FEE
  ESCORT_FEE
  TAMPER_SEAL_FEE
  WITHDRAWAL_FEE
  LIQUIDATION_COMMISSION
  WIRE_TRANSFER_FEE
  KYC_FEE
  DOCUMENTATION_FEE
  LATE_FEE
  DEMURRAGE_FEE
  LATE_PAYMENT_PENALTY
  OTHER
}

model VaultInvoice {
  id              String          @id @default(cuid())
  invoiceNumber   String          @unique
  depositId       String
  clientId        String
  issueDate       DateTime        @default(now())
  dueDate         DateTime
  paidAt          DateTime?
  periodStart     DateTime?
  periodEnd       DateTime?
  currency        String          @default("USD")
  subtotal        Float           @default(0)
  taxRate         Float           @default(0)
  taxAmount       Float           @default(0)
  total           Float           @default(0)
  amountPaid      Float           @default(0)
  balanceDue      Float           @default(0)
  status          INVOICE_STATUS  @default(DRAFT)
  paymentMethod   String?
  paymentRef      String?
  notes           String?
  deposit         VaultDeposit    @relation(fields: [depositId], references: [id], onDelete: Cascade)
  client          User            @relation("VaultInvoices", fields: [clientId], references: [id], onDelete: Cascade)
  items           VaultInvoiceItem[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model VaultInvoiceItem {
  id          String              @id @default(cuid())
  invoiceId   String
  type        INVOICE_ITEM_TYPE
  description String
  quantity    Float               @default(1)
  unitPrice   Float
  amount      Float
  invoice     VaultInvoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

enum TRANSFER_STATUS {
  INITIATED
  COMPLIANCE_CHECK
  APPROVED
  IN_TRANSIT
  RECEIVED
  COMPLETED
  CANCELLED
}

enum BENEFICIARY_STATUS {
  PENDING
  VERIFIED
  REJECTED
  REVOKED
}

model VaultTransfer {
  id                   String          @id @default(cuid())
  depositId            String
  transferNumber       String          @unique
  sourceVault          String
  sourceUnit           String?
  destinationVault     String
  destinationUnit      String?
  destinationCustodian String?
  destinationContact   String?
  status               TRANSFER_STATUS @default(INITIATED)
  transferType         String          @default("FULL")
  weightTransferred    Float
  itemsTransferred     String?
  estimatedArrival     DateTime?
  actualArrival        DateTime?
  securityEscortRef    String?
  sealNumbers          String?
  chainOfCustodyDoc    String?
  transitInsured       Boolean         @default(true)
  transitInsuredValue  Float?
  transitInsurer       String?
  transferFee          Float?
  insuranceFee         Float?
  initiatedBy          String
  initiatedAt          DateTime        @default(now())
  approvedBy           String?
  approvedAt           DateTime?
  completedBy          String?
  completedAt          DateTime?
  cancellationReason   String?
  notes                String?
  deposit              VaultDeposit    @relation(fields: [depositId], references: [id], onDelete: Cascade)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model VaultBeneficiary {
  id                String             @id @default(cuid())
  depositId         String
  name              String
  relationship      String
  email             String?
  phone             String?
  address           String?
  dateOfBirth       DateTime?
  idType            String?
  idNumber          String?
  idExpiryDate      DateTime?
  idDocumentUrl     String?
  allocationPercent Float              @default(100)
  status            BENEFICIARY_STATUS @default(PENDING)
  verifiedBy        String?
  verifiedAt        DateTime?
  rejectionReason   String?
  powerOfAttorney   Boolean            @default(false)
  poaDocumentUrl    String?
  authorizedActions String?
  notes             String?
  deposit           VaultDeposit       @relation(fields: [depositId], references: [id], onDelete: Cascade)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}
